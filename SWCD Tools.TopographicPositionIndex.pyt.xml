<metadata xml:lang="en"><Esri><CreaDate>20260330</CreaDate><CreaTime>16345900</CreaTime><ArcGISFormat>1.0</ArcGISFormat><SyncOnce>TRUE</SyncOnce><ModDate>20260422</ModDate><ModTime>15471600</ModTime><scaleRange><minScale>150000000</minScale><maxScale>5000</maxScale></scaleRange><ArcGISProfile>ItemDescription</ArcGISProfile></Esri><tool name="TopographicPositionIndex" displayname="Topographic Position Index (TPI)" toolboxalias="SWCD Tools" xmlns=""><arcToolboxHelpPath>c:\program files\arcgis\pro\Resources\Help\gp</arcToolboxHelpPath><parameters><param name="dem" displayname="DEM" type="Required" direction="Input" datatype="Raster Layer" expression="dem"><dialogReference>&lt;DIV STYLE="text-align:Left;"&gt;&lt;DIV&gt;&lt;DIV&gt;&lt;P&gt;&lt;SPAN STYLE="font-size:12pt"&gt;Elevation data source&lt;/SPAN&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/DIV&gt;&lt;/DIV&gt;</dialogReference></param><param name="analysis_area" displayname="Analysis Area" type="Optional" direction="Input" datatype="Extent" expression="{analysis_area}"><dialogReference>&lt;DIV STYLE="text-align:Left;"&gt;&lt;P&gt;&lt;SPAN STYLE="font-size:12pt"&gt;Analysis area to calculate TPI within&lt;/SPAN&gt;&lt;/P&gt;&lt;/DIV&gt;</dialogReference></param><param name="neighborhood" displayname="Neighborhood" type="Optional" direction="Input" datatype="Neighborhood" expression="{neighborhood}"><dialogReference>&lt;DIV STYLE="text-align:Left;"&gt;&lt;DIV&gt;&lt;DIV&gt;&lt;P&gt;&lt;SPAN&gt;Neighborhood around each cell to calculate the average elevation for comparison to the current cell. &lt;/SPAN&gt;&lt;A href="https://pro.arcgis.com/en/pro-app/latest/tool-reference/spatial-analyst/how-topographic-position-index-works.htm" target="_blank" STYLE="text-decoration:underline;"&gt;&lt;SPAN&gt;See ArcGIS Pro documentation for more information.&lt;/SPAN&gt;&lt;/A&gt;&lt;/P&gt;&lt;P&gt;&lt;SPAN&gt;Note: neighborhood size must be larger than DEM cell size for meaningful results. Find map units by examining it's properties: "Right Click the map in Contents -&amp;gt; Properties"&lt;/SPAN&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/DIV&gt;&lt;/DIV&gt;</dialogReference></param><param name="out_features" displayname="Output Features" type="Required" direction="Output" datatype="Feature Class" expression="out_features"><dialogReference>&lt;DIV STYLE="text-align:Left;"&gt;&lt;DIV&gt;&lt;P&gt;&lt;SPAN&gt;Output path of topographic position index (TPI) raster&lt;/SPAN&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/DIV&gt;</dialogReference></param></parameters><summary>&lt;DIV STYLE="text-align:Left;"&gt;&lt;DIV&gt;&lt;DIV&gt;&lt;P&gt;&lt;SPAN&gt;Calculate Topographic Position Index (TPI) from a DEM. Based off of research by &lt;/SPAN&gt;&lt;A href="https://env761.github.io/assets/files/tpi-poster-tnc_18x22.pdf" target="_blank" STYLE="text-decoration:underline;"&gt;&lt;SPAN&gt;Weiss 2001&lt;/SPAN&gt;&lt;/A&gt;&lt;/P&gt;&lt;P&gt;&lt;SPAN&gt;Note: &lt;/SPAN&gt;&lt;A href="https://pro.arcgis.com/en/pro-app/latest/tool-reference/spatial-analyst/how-topographic-position-index-works.htm" target="_blank" STYLE="text-decoration:underline;"&gt;&lt;SPAN&gt;this feature exists in ArcGIS Pro as of v3.6&lt;/SPAN&gt;&lt;/A&gt;&lt;/P&gt;&lt;/DIV&gt;&lt;/DIV&gt;&lt;/DIV&gt;</summary></tool><dataIdInfo><idCitation><resTitle>Topographic Position Index (TPI)</resTitle></idCitation><searchKeys><keyword>Terrain Analysis Topographic Position Index TPI Focal Statistics Relative Features</keyword></searchKeys></dataIdInfo><distInfo><distributor><distorFormat><formatName>ArcToolbox Tool</formatName></distorFormat></distributor></distInfo><mdHrLv><ScopeCd value="005"/></mdHrLv><mdDateSt Sync="TRUE">20260422</mdDateSt></metadata>
